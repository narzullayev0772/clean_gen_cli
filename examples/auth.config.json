{
  "name": "auth",
  "functions": [
    {
      "name": "signIn",
      "api": "/api/auth/sign-in",
      "method": "POST",
      "request": {
        "email": "string",
        "password": "string"
      },
      "response": {
        "token": "string",
        "user": {
          "id": 1,
          "email": "string",
          "name": "string"
        }
      }
    },
    {
      "name": "getUsersList",
      "api": "/users/list",
      "pagination": true,
      "response": [
        {
          "id": 1,
          "email": "string",
          "name": "string"
        }
      ],
      "request": {
        "page": 1,
        "pageSize": 10
      }
    }
  ]
}
